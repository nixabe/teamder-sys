# Copy this file to .env and fill in your values.

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name
DB_NAME=teamder

# JWT signing secret — change this to a long random string in production!
JWT_SECRET=teamder-dev-secret-change-in-production

# Rocket address / port (optional — defaults to 127.0.0.1:8000)
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8000

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# ── SMTP (passwordless verification-code emails) ──────────────────────────────
# When SMTP_HOST is unset/empty the mailer runs in DEV MODE: codes are logged
# and returned in the API response (dev_code) instead of being emailed.
# Set SMTP_HOST to enable real delivery.
SMTP_HOST=
# Port: 587 = STARTTLS (default), 465 = implicit TLS
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# From address; defaults to SMTP_USERNAME if omitted. A display name is allowed:
#   SMTP_FROM=Teamder <no-reply@yourdomain.com>
SMTP_FROM=

# Frontend base URL used to build the magic verification link in emails
APP_BASE_URL=http://localhost:3000
