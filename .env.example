# Copy this file to .env and fill in your values.

# MongoDB connection URI
MONGODB_URI=mongodb://localhost:27017

# MongoDB database name
DB_NAME=teamder

# JWT signing secret — change this to a long random string in production!
JWT_SECRET=teamder-dev-secret-change-in-production

# Rocket address / port (optional — defaults to 127.0.0.1:8000)
ROCKET_ADDRESS=127.0.0.1
ROCKET_PORT=8000

# Log level: error | warn | info | debug | trace
RUST_LOG=info

# ── SMTP (passwordless verification-code emails) ──────────────────────────────
# When SMTP_HOST is unset/empty the mailer runs in DEV MODE: codes are logged
# and returned in the API response (dev_code) instead of being emailed.
# Set SMTP_HOST to enable real delivery.
SMTP_HOST=
# Port: 587 = STARTTLS (default), 465 = implicit TLS
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# From address; defaults to SMTP_USERNAME if omitted. A display name is allowed:
#   SMTP_FROM=Teamder <no-reply@yourdomain.com>
SMTP_FROM=

# Frontend base URL used to build the magic verification link in emails
APP_BASE_URL=http://localhost:3000

# Email domain allowed to REGISTER new accounts (login is never restricted).
# Defaults to cloud.fju.edu.tw. Set to "*" (or empty) to allow any domain.
REGISTER_EMAIL_DOMAIN=cloud.fju.edu.tw

# Minimum days both reviewer and reviewee must have belonged to the same
# completed project/study group before a peer review can be submitted.
# 0 disables the backend age gate for testing; set to 7 to enforce it.
REVIEW_MIN_COLLAB_DAYS=0

# LLM used by the peer-review assistant. The server must expose an
# OpenAI-compatible /v1/chat/completions API. LLM_API_KEY may be left empty
# for local llama-server deployments without auth.
LLM_BASE_URL=http://1.34.172.117:8000
LLM_MODEL=Qwen3.6-27B-MTP-Q4
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=45
